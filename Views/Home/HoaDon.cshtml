@model HeThongQuanLiBia.Models.HoaDon

@{
    ViewData["Title"] = "Hóa đơn";
    decimal tong = ViewBag.TongCong;
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-body">

            <h2 class="text-center mb-4">
                HÓA ĐƠN THANH TOÁN
            </h2>

            <div class="mb-3">
                <strong>Bàn:</strong> @Model.Ban?.TenBan
            </div>

            <div class="mb-3">
                <strong>Thời gian:</strong>
                @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </div>

            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Dịch vụ</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.ChiTietDichVus)
                    {
                        <tr>
                            <td>@item.DichVu?.TenDichVu</td>
                            <td>@item.SoLuong</td>
                            <td>@($"{item.DonGiaTaiThoiDiemBan:N0} đ")</td>
                            <td>@($"{item.SoLuong * item.DonGiaTaiThoiDiemBan:N0} đ")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="text-end mt-4">
                <h3 class="text-danger">
                    Tổng cộng: @($"{tong:N0} đ")
                </h3>
            </div>

            <div class="text-center mt-4">
                <a asp-action="Index" class="btn btn-primary">
                    Quay lại POS
                </a>

                <button onclick="window.print()" class="btn btn-success">
                    In hóa đơn
                </button>
            </div>

        </div>
    </div>
</div>