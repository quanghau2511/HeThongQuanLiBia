@model IEnumerable<HeThongQuanLiBia.Models.HoaDon>
@{
    ViewData["Title"] = "Báo cáo Doanh thu";
}
@* hhhh *@
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="fas fa-chart-line text-primary me-2"></i>BÁO CÁO DOANH THU
            </h2>
            <p class="text-muted mb-0">Thống kê hoạt động kinh doanh và bóc tách dữ liệu hóa đơn</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary fw-bold px-3 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Quay lại Bán hàng
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
        <div class="card-body bg-light p-3" style="border-radius: 12px;">
            <form method="get" asp-action="DoanhThu" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-secondary">Từ ngày</label>
                    <input type="date" name="tuNgay" value="@ViewBag.TuNgay" class="form-control border-0 shadow-sm" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-secondary">Đến ngày</label>
                    <input type="date" name="denNgay" value="@ViewBag.DenNgay" class="form-control border-0 shadow-sm" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow border-0">
                        <i class="fas fa-filter me-2"></i>LỌC DỮ LIỆU
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary text-white h-100 shadow" style="border-radius: 15px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-bold text-uppercase small mb-2">Tổng doanh thu</h6>
                        <h3 class="fw-bold mb-0">@(((decimal)ViewBag.TongDoanhThu).ToString("N0")) đ</h3>
                    </div>
                    <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                        <i class="fas fa-wallet fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 bg-success text-white h-100 shadow" style="border-radius: 15px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-bold text-uppercase small mb-2">Tiền giờ tích lũy</h6>
                        <h3 class="fw-bold mb-0">@(((decimal)ViewBag.TongTienGio).ToString("N0")) đ</h3>
                    </div>
                    <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                        <i class="fas fa-clock fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 bg-info text-white h-100 shadow" style="border-radius: 15px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 fw-bold text-uppercase small mb-2">Tiền món & dịch vụ</h6>
                        <h3 class="fw-bold mb-0">@(((decimal)ViewBag.TongTienDichVu).ToString("N0")) đ</h3>
                    </div>
                    <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                        <i class="fas fa-ice-cream fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 bg-warning text-dark h-100 shadow" style="border-radius: 15px;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-dark-50 fw-bold text-uppercase small mb-2">Số lượng bill</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.SoLuongHoaDon bill chốt</h3>
                    </div>
                    <div class="bg-dark bg-opacity-10 p-3 rounded-circle">
                        <i class="fas fa-file-invoice-dollar fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px;">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-secondary"><i class="fas fa-history me-2"></i>Danh sách hóa đơn đã chốt</h5>
            <span class="badge bg-light text-dark p-2 border fw-bold">Hiển thị thực tế lịch sử</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Mã HD</th>
                            <th>Tên Bàn</th>
                            <th>Giờ Vào</th>
                            <th>Giờ Ra</th>
                            <th class="text-end pe-4" style="width: 200px;">Thành Tiền Bill</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var hd in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@hd.HoaDonId</td>
                                    <td>
                                        <span class="badge bg-dark px-3 py-2 fw-bold" style="font-size: 0.85rem;">
                                            @(hd.Ban?.TenBan ?? "Bàn đã xóa")
                                        </span>
                                    </td>
                                    <td class="text-secondary small">@hd.GioVao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-secondary small">@(hd.GioRa?.ToString("dd/MM/yyyy HH:mm") ?? "---")</td>
                                    <td class="text-end pe-4 fw-bold text-danger" style="font-size: 1.05rem;">
                                        @hd.TongTien.ToString("N0") đ
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-folder-open fa-3x mb-3 text-opacity-25 text-secondary"></i>
                                    <p class="mb-0 fw-bold">Không tìm thấy dữ liệu hóa đơn đã thanh toán nào.</p>
                                    <small class="text-muted">Hãy thử thay đổi khoảng thời gian lọc ở trên.</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>