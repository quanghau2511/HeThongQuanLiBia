@model IEnumerable<object>

@{
    ViewData["Title"] = "Báo cáo Doanh Thu";
    Layout = "~/Views/Shared/_Layout.cshtml";

    decimal tongDoanhThu = 0;
    int tongSoLuot = 0;

    if (Model != null)
    {
        foreach (dynamic item in Model)
        {
            tongDoanhThu += item.TongTien;
        }
        tongSoLuot = Model.Count();
    }
}

<div class="container-fluid mt-2 px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">
                <i class="fas fa-chart-line text-primary me-2"></i>THỐNG KÊ DOANH THU
            </h2>
            <p class="text-muted mb-0">Dữ liệu doanh thu thực tế ghi nhận từ hệ thống câu lạc bộ</p>
        </div>
        
        <form method="get" asp-controller="Home" asp-action="DoanhThu" class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="small text-muted fw-bold d-block mb-1">Từ ngày:</label>
                <input type="date" name="fromDate" class="form-control shadow-sm" value="@ViewBag.FromDate" />
            </div>
            <div>
                <label class="small text-muted fw-bold d-block mb-1">Đến ngày:</label>
                <input type="date" name="toDate" class="form-control shadow-sm" value="@ViewBag.ToDate" />
            </div>
            <div>
                <button type="submit" class="btn btn-primary fw-bold px-3 py-2 shadow-sm">
                    <i class="fas fa-filter me-1"></i> Lọc kết quả
                </button>
            </div>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-white-50 fw-bold small mb-1">Tổng doanh thu kì lọc</h6>
                        <h2 class="fw-bold m-0">@($"{tongDoanhThu:N0} đ")</h2>
                    </div>
                    <i class="fas fa-money-check-alt fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-white-50 fw-bold small mb-1">Số lượt bàn đã thanh toán</h6>
                        <h2 class="fw-bold m-0">@tongSoLuot lượt chơi</h2>
                    </div>
                    <i class="fas fa-calculator fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white py-3 border-bottom-0">
            <h5 class="fw-bold m-0 text-dark">
                <i class="fas fa-list-ol text-secondary me-2"></i>Lịch sử giao dịch thanh toán bàn bida
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã Hóa Đơn</th>
                            <th>Bàn Chơi</th>
                            <th>Thời Gian Vào</th>
                            <th>Thời Gian Ra</th>
                            <th class="text-end pe-4">Tổng Số Tiền Thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (dynamic hd in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@hd.HoaDonId</td>
                                    <td>
                                        <span class="badge bg-dark px-3 py-2 rounded-2">
                                            <i class="fas fa-trophy text-warning me-1"></i>
                                            @(hd.Ban != null ? hd.Ban.TenBan : $"Bàn số {hd.BanId}")
                                        </span>
                                    </td>
                                    <td class="text-muted">@hd.GioVao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-muted">@(hd.GioRa != null ? hd.GioRa.ToString("dd/MM/yyyy HH:mm") : "N/A")</td>
                                    <td class="text-end pe-4 fw-bold text-danger fs-6">@($"{hd.TongTien:N0} đ")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-ban d-block fs-1 mb-2 text-secondary"></i>
                                    Không có dữ liệu trong khoảng thời gian được lọc.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>