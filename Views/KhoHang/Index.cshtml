@model IEnumerable<HeThongQuanLiBia.Models.DichVu>
@{
    ViewData["Title"] = "Kho Hàng & Danh Mục";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-box-seam"></i> KHO HÀNG & DANH MỤC</h2>
        <button type="button" class="btn btn-success fw-bold" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg"></i> THÊM MẶT HÀNG
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white pt-3 pb-0">
            <ul class="nav nav-tabs border-bottom-0" id="khoHangTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-nuoc" type="button">
                        <i class="bi bi-cup-straw"></i> ĐỒ UỐNG
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-monan" type="button">
                        <i class="bi bi-egg-fried"></i> MÓN ĂN
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-phukien" type="button">
                        <i class="bi bi-controller"></i> PHỤ KIỆN / THUÊ
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body">
            <div class="tab-content" id="khoHangTabContent">
                
                <div class="tab-pane fade show active" id="tab-nuoc">
                    @await Html.PartialAsync("_BangHangHoa", Model.Where(m => m.LoaiDichVu == 1))
                </div>

                <div class="tab-pane fade" id="tab-monan">
                    @await Html.PartialAsync("_BangHangHoa", Model.Where(m => m.LoaiDichVu == 2))
                </div>

                <div class="tab-pane fade" id="tab-phukien">
                    @await Html.PartialAsync("_BangHangHoa", Model.Where(m => m.LoaiDichVu == 3))
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ThemMatHang" asp-controller="KhoHang" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">THÊM MẶT HÀNG MỚI</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên mặt hàng</label>
                        <input type="text" class="form-control" name="TenDichVu" required placeholder="VD: Mì xào bò, Trà đào..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                        <input type="number" class="form-control" name="Gia" required min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục</label>
                        <select class="form-select" name="LoaiDichVu" required>
                            <option value="1">Đồ uống</option>
                            <option value="2">Món ăn</option>
                            <option value="3">Phụ kiện / Thuê</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>