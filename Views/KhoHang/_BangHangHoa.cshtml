@using HeThongQuanLiBia.Models
@model IEnumerable<DichVu>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã HH</th>
                <th>Tên mặt hàng</th>
                <th>Đơn giá</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">#@item.DichVuId</td>
                        <td class="fw-bold">@item.TenDichVu</td>
                        <td class="text-primary fw-semibold">@($"{item.Gia:N0} đ")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </button>
                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        <i>Chưa có mặt hàng nào trong danh mục này.</i>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>