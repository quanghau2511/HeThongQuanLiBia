@model HeThongQuanLiBia.Models.DatBan
@{
    ViewData["Title"] = "Chi tiết đặt bàn";
    var serviceTotal = Model.DatBanDichVus?.Sum(item => item.SoLuong * item.DonGiaTaiThoiDiemBan) ?? 0m;
    var durationHours = (Model.GioKetThuc.ToTimeSpan() - Model.GioBatDau.ToTimeSpan()).TotalHours;
    var tableTotal = (decimal)durationHours * (Model.Ban?.GiaTheoGio ?? 0m);
    var total = serviceTotal + tableTotal;
}

<div class="container-fluid px-3 px-lg-4 py-3">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <p class="text-muted mb-1">CHI TIẾT BOOKING</p>
            <h1 class="h2 fw-bold text-dark mb-0">Đặt bàn #@Model.DatBanId</h1>
            <p class="text-muted mb-0">Xem thông tin khách hàng, bàn, món chọn, và cập nhật trạng thái.</p>
        </div>

        <div>
            @switch (Model.TrangThai)
            {
                case 1:
                    <span class="badge bg-success-subtle text-success fs-6">Đã xác nhận</span>
                    break;
                case 2:
                    <span class="badge bg-danger-subtle text-danger fs-6">Đã hủy</span>
                    break;
                default:
                    <span class="badge bg-warning-subtle text-warning fs-6">Chờ xác nhận</span>
                    break;
            }
        </div>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>
            @ViewBag.SuccessMessage
        </div>
    }

    <div class="row g-4">
        <div class="col-xl-5">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold text-dark mb-3">Thông tin khách hàng</h2>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Khách hàng:</strong> @Model.KhachHang?.HoTen</li>
                        <li class="mb-2"><strong>Số điện thoại:</strong> @Model.KhachHang?.SoDienThoai</li>
                        <li class="mb-2"><strong>Email:</strong> @Model.KhachHang?.Email</li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold text-dark mb-3">Thông tin đặt bàn</h2>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Bàn:</strong> @Model.Ban?.TenBan</li>
                        <li class="mb-2"><strong>Ngày:</strong> @Model.NgayDat.ToString("dd/MM/yyyy")</li>
                        <li class="mb-2"><strong>Giờ:</strong> @Model.GioBatDau.ToString(@"hh\:mm") - @Model.GioKetThuc.ToString(@"hh\:mm")</li>
                        <li class="mb-2"><strong>Ghi chú:</strong> @((string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu))</li>
                        <li class="mb-2"><strong>Giá bàn/giờ:</strong> @((Model.Ban?.GiaTheoGio ?? 0m).ToString("N0")) đ</li>
                        <li class="mb-2"><strong>Thời gian chơi:</strong> @durationHours.ToString("0.##") giờ</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="h5 fw-bold text-dark mb-1">Chi tiết dịch vụ</h2>
                            <p class="text-muted small mb-0">Các món và phụ kiện đã chọn.</p>
                        </div>
                        <div class="badge bg-primary-subtle text-primary">@(Model.DatBanDichVus?.Count() ?? 0) mục</div>
                    </div>

                    @if (!(Model.DatBanDichVus?.Any() ?? false))
                    {
                        <div class="alert alert-light border rounded-4 mb-0">Khách hàng chưa chọn dịch vụ kèm theo.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Dịch vụ</th>
                                        <th>Số lượng</th>
                                        <th>Đơn giá</th>
                                        <th>Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.DatBanDichVus)
                                    {
                                        <tr>
                                            <td>@(item.DichVu?.TenDichVu ?? "Dịch vụ chưa xác định")</td>
                                            <td>@item.SoLuong</td>
                                            <td>@item.DonGiaTaiThoiDiemBan.ToString("N0") đ</td>
                                            <td class="fw-bold text-primary">@((item.SoLuong * item.DonGiaTaiThoiDiemBan).ToString("N0")) đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold text-dark mb-3">Tổng hóa đơn</h2>
                    <div class="rounded-4 bg-light p-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tiền bàn</span>
                            <span class="fw-semibold">@tableTotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Dịch vụ</span>
                            <span class="fw-semibold">@serviceTotal.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 mt-2">
                            <span class="fw-bold">Tổng cộng</span>
                            <span class="fw-bold text-primary fs-4">@total.ToString("N0") đ</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h3 class="h6 fw-bold text-dark mb-2">Cập nhật trạng thái</h3>
                        <div class="d-flex flex-wrap gap-2">
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.DatBanId" />
                                <input type="hidden" name="status" value="0" />
                                <button type="submit" class="btn btn-warning" @(Model.TrangThai == 0 ? "disabled" : "")>Chờ xác nhận</button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.DatBanId" />
                                <input type="hidden" name="status" value="1" />
                                <button type="submit" class="btn btn-success" @(Model.TrangThai == 1 ? "disabled" : "")>Đã xác nhận</button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.DatBanId" />
                                <input type="hidden" name="status" value="2" />
                                <button type="submit" class="btn btn-outline-danger" @(Model.TrangThai == 2 ? "disabled" : "")>Hủy</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
