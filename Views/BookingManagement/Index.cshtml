@model IEnumerable<HeThongQuanLiBia.Models.DatBan>
@{
    ViewData["Title"] = "Quản lý đặt bàn";
}

<div class="container-fluid px-3 px-lg-4 py-3">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <p class="text-muted mb-1">QUẢN LÝ</p>
            <h1 class="h2 fw-bold text-dark mb-0">Danh sách đặt bàn</h1>
            <p class="text-muted mb-0">Theo dõi booking, lọc theo trạng thái, tìm kiếm khách hàng hoặc bàn.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary-subtle text-primary">Tổng: @ViewBag.TotalCount</span>
            <span class="badge bg-warning-subtle text-warning">Chờ xác nhận: @ViewBag.PendingCount</span>
            <span class="badge bg-success-subtle text-success">Đã xác nhận: @ViewBag.ConfirmedCount</span>
            <span class="badge bg-danger-subtle text-danger">Đã hủy: @ViewBag.CancelledCount</span>
        </div>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>
            @ViewBag.SuccessMessage
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tìm kiếm</label>
                    <input type="text" class="form-control" name="search" value="@ViewBag.Search" placeholder="Tên, SDT, bàn, ghi chú" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Trạng thái</label>
                    <select class="form-select" name="status">
                        <option value="">Tất cả</option>
                        <option value="0" selected="@(ViewBag.Status == 0)">Chờ xác nhận</option>
                        <option value="1" selected="@(ViewBag.Status == 1)">Đã xác nhận</option>
                        <option value="2" selected="@(ViewBag.Status == 2)">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Từ ngày</label>
                    <input type="date" class="form-control" name="from" value="@ViewBag.From" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Đến ngày</label>
                    <input type="date" class="form-control" name="to" value="@ViewBag.To" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Mã</th>
                        <th>Khách hàng</th>
                        <th>Bàn</th>
                        <th>Ngày / giờ</th>
                        <th>Trạng thái</th>
                        <th>Tổng tiền</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        var durationHours = (booking.GioKetThuc.ToTimeSpan() - booking.GioBatDau.ToTimeSpan()).TotalHours;
                        var serviceTotal = booking.DatBanDichVus?.Sum(item => item.SoLuong * item.DonGiaTaiThoiDiemBan) ?? 0m;
                        var tableTotal = (decimal)durationHours * (booking.Ban?.GiaTheoGio ?? 0m);
                        var total = serviceTotal + tableTotal;

                        <tr>
                            <td class="fw-bold">#@booking.DatBanId</td>
                            <td>
                                <div class="fw-semibold">@booking.KhachHang?.HoTen</div>
                                <div class="small text-muted">@booking.KhachHang?.SoDienThoai</div>
                            </td>
                            <td>@booking.Ban?.TenBan</td>
                            <td>
                                <div>@booking.NgayDat.ToString("dd/MM/yyyy")</div>
                                <div class="small text-muted">@booking.GioBatDau.ToString(@"hh\:mm") - @booking.GioKetThuc.ToString(@"hh\:mm")</div>
                            </td>
                            <td>
                                @switch (booking.TrangThai)
                                {
                                    case 1:
                                        <span class="badge bg-success-subtle text-success">Đã xác nhận</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-danger-subtle text-danger">Đã hủy</span>
                                        break;
                                    default:
                                        <span class="badge bg-warning-subtle text-warning">Chờ xác nhận</span>
                                        break;
                                }
                            </td>
                            <td class="fw-bold text-primary">@total.ToString("N0") đ</td>
                            <td>
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@booking.DatBanId">Chi tiết</a>
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.DatBanId" />
                                        <input type="hidden" name="status" value="1" />
                                        <button type="submit" class="btn btn-sm btn-success" @(booking.TrangThai == 1 ? "disabled" : "")>Xác nhận</button>
                                    </form>
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.DatBanId" />
                                        <input type="hidden" name="status" value="2" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" @(booking.TrangThai == 2 ? "disabled" : "")>Hủy</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
