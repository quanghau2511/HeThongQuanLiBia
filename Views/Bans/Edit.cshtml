@model HeThongQuanLiBia.Models.Bans
@{
    ViewData["Title"] = "Cập nhật bàn bida";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
            <h4 class="fw-bold mb-3 text-dark text-uppercase">
                <i class="fas fa-edit text-warning me-2"></i>Cập nhật thông tin bàn
            </h4>
            <hr />
            
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="BanId" />

                <div class="mb-3">
                    <label asp-for="TenBan" class="form-label fw-bold text-secondary"></label>
                    <input asp-for="TenBan" class="form-control form-control-lg rounded-3" placeholder="Nhập tên hoặc số bàn bida..." />
                    <span asp-validation-for="TenBan" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GiaTheoGio" class="form-label fw-bold text-secondary"></label>
                    <input asp-for="GiaTheoGio" type="number" step="0.01" class="form-control form-control-lg rounded-3" placeholder="Nhập giá theo giờ..." />
                    <span asp-validation-for="GiaTheoGio" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TinhTrang" class="form-label fw-bold text-secondary">Tình trạng cơ sở vật chất</label>
                    <select asp-for="TinhTrang" class="form-select form-select-lg rounded-3">
                        <option value="Tốt">Còn tốt - Hoạt động bình thường</option>
                        <option value="Bị hư ít">Bị hư ít (Vải hơi xước, cơ cũ...)</option>
                        <option value="Bị hư nhiều">Bị hư nhiều (Cần bảo trì gấp)</option>
                    </select>
                    <span asp-validation-for="TinhTrang" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TrangThai" class="form-label fw-bold text-secondary">Trạng thái bàn</label>
                    <select asp-for="TrangThai" class="form-select form-select-lg rounded-3">
                        <option value="0">Bàn trống</option>
                        <option value="1">Đang có khách</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold text-dark px-4 py-2 rounded-3 flex-grow-1 shadow-sm">
                        <i class="fas fa-save me-2"></i>Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4 py-2 rounded-3 text-secondary">
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}