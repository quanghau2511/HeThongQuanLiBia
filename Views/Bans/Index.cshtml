@model IEnumerable<HeThongQuanLiBia.Models.Bans>
@{
    ViewData["Title"] = "Quản lý bàn bida";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1 text-dark">
                <i class="fas fa-table text-primary me-2"></i>QUẢN LÝ DANH SÁCH BÀN BIDA
            </h4>
            <p class="text-muted small mb-0">Cấu hình thông tin, trạng thái hoạt động và tình trạng cơ sở vật chất của bàn.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary fw-bold rounded-3 px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i>Thêm bàn mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width: 10%">Mã Số</th>
                    <th style="width: 25%">Tên Gọi / Số Bàn</th>
                    <th class="text-center" style="width: 15%">Giá / giờ</th>
                    <th class="text-center" style="width: 15%">Trạng Thái Chơi</th>
                    <th class="text-center" style="width: 20%">Tình Trạng Bàn</th>
                    <th class="text-center" style="width: 15%">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Chưa có dữ liệu bàn bida nào được tạo.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-secondary">#@item.BanId</td>
                            <td><span class="fw-bold text-dark fs-6">@item.TenBan</span></td>
                            <td class="text-center">
                                @item.GiaTheoGio.ToString("N0") VNĐ
                            </td>
                            <td class="text-center">
                                @if (item.TrangThai == 1)
                                {
                                    <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fas fa-play-circle me-1"></i> Đang có khách</span>
                                }
                                else
                                {
                                    <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-check-circle me-1"></i> Bàn trống</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.TinhTrang == "Bị hư nhiều")
                                {
                                    <span class="badge bg-light text-danger border border-danger px-3 py-2 rounded-pill fw-bold">
                                        <i class="fas fa-exclamation-triangle me-1"></i> Bị hư nhiều
                                    </span>
                                }
                                else if (item.TinhTrang == "Bị hư ít")
                                {
                                    <span class="badge bg-light text-warning border border-warning px-3 py-2 rounded-pill fw-bold">
                                        <i class="fas fa-tools me-1"></i> Bị hư ít
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-success border border-success px-3 py-2 rounded-pill fw-bold">
                                        <i class="fas fa-shield-alt me-1"></i> Tốt
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.BanId" class="btn btn-sm btn-outline-info px-3 rounded-pill">
                                        <i class="fas fa-info-circle me-1"></i> Xem
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.BanId" class="btn btn-sm btn-outline-warning px-3 rounded-pill">
                                        <i class="fas fa-edit me-1"></i> Sửa
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.BanId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bàn này không?');" class="m-0">
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill">
                                            <i class="fas fa-trash-alt me-1"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>