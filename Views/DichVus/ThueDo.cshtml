@model IEnumerable<HeThongQuanLiBia.Models.DichVu>

@{
    ViewData["Title"] = "Dịch Vụ Thuê Dụng Cụ";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-tools me-2 text-secondary"></i>Quản Lý Dịch Vụ Thuê (Cơ/Lơ/Găng)</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Thêm Dụng Cụ Mới</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã DV</th>
                        <th>Tên dụng cụ</th>
                        <th>Đơn vị tính</th>
                        <th>Giá thuê</th>
                        <th>Số lượng sẵn có</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DichVuId</td>
                                <td class="fw-bold">@item.TenDichVu</td>
                                <td><span class="badge bg-secondary">@item.DonViTinh</span></td>
                                <td class="text-danger fw-bold">@item.Gia.ToString("#,##0") đ</td>
                                <td>@item.SoLuongTon cái</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.DichVuId" class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.DichVuId" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Chưa có phụ kiện cho thuê nào trong hệ thống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>