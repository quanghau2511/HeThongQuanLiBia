@model HeThongQuanLiBia.Models.Bans
@{
    ViewData["Title"] = "Thêm bàn bida mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
            <h4 class="fw-bold mb-3 text-dark text-uppercase">
                <i class="fas fa-plus-circle text-primary me-2"></i>Thêm bàn bida mới
            </h4>
            <hr />
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="TrangThai" value="0" />

                <div class="mb-3">
                    <label asp-for="TenBan" class="form-label fw-bold text-secondary"></label>
                    <input asp-for="TenBan" class="form-control form-control-lg rounded-3" placeholder="Ví dụ: Bàn 01, Bàn lỗ 02..." />
                    <span asp-validation-for="TenBan" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TinhTrang" class="form-label fw-bold text-secondary">Tình trạng ban đầu</label>
                    <select asp-for="TinhTrang" class="form-select form-select-lg rounded-3">
                        <option value="Tốt">Còn tốt - Hoạt động bình thường</option>
                        <option value="Bị hư ít">Bị hư ít (Vải hơi xước, cơ cũ...)</option>
                        <option value="Bị hư nhiều">Bị hư nhiều (Cần bảo trì gấp)</option>
                    </select>
                    <span asp-validation-for="TinhTrang" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary fw-bold px-4 py-2 rounded-3 flex-grow-1 shadow-sm">
                        <i class="fas fa-check me-2"></i>Xác nhận thêm
                    </button>
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4 py-2 rounded-3 text-secondary">
                        Hủy quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}