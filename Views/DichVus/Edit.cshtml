@model HeThongQuanLiBia.Models.DichVu
@{
    int loai = ViewBag.LoaiHienTai ?? Model.LoaiDichVu;
    ViewData["Title"] = "Chỉnh sửa thông tin";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
            <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">
                <i class="fas fa-edit text-primary rural me-2"></i><span>CHỈNH SỬA THÔNG TIN (#@Model.DichVuId)</span>
            </h4>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="DichVuId" />
                <input type="hidden" asp-for="LoaiDichVu" />

                <div class="mb-3">
                    <label asp-for="TenDichVu" class="form-label fw-bold">Tên Gọi Sản Phẩm</label>
                    <input asp-for="TenDichVu" class="form-control" required />
                    <span asp-validation-for="TenDichVu" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DonViTinh" class="form-label fw-bold">Đơn Vị Tính</label>
                        <input asp-for="DonViTinh" class="form-control" required />
                        <span asp-validation-for="DonViTinh" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoLuongTon" class="form-label fw-bold">Số Lượng Tồn</label>
                        <input asp-for="SoLuongTon" class="form-control" type="number" min="0" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Gia" class="form-label fw-bold">Đơn Giá Bán (VNĐ)</label>
                    <input asp-for="Gia" class="form-control text-end fw-bold text-primary fs-5" type="number" min="0" required />
                    <span asp-validation-for="Gia" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="@(loai == 2 ? "ThueDo" : "Index")" class="btn btn-light px-4 rounded-3 border">Hủy</a>
                    <button type="submit" class="btn btn-warning fw-bold px-4 rounded-3 text-dark shadow-sm">
                        <i class="fas fa-check me-2"></i>Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>